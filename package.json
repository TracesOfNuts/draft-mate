{
  "name": "draft-mate",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first email triage engine: fetch, rank, and explain a backlog of emails. Privacy by construction — all analysis runs locally.",
  "type": "module",
  "bin": {
    "draft-mate": "dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "triage": "node dist/cli.js",
    "serve": "node dist/cli.js serve",
    "start": "node dist/cli.js serve",
    "dev": "tsc -p tsconfig.json && node dist/cli.js serve",
    "demo": "node dist/cli.js triage --account demo --unread",
    "test": "node --test \"dist/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
